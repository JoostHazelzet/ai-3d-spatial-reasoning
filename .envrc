# .envrc template for Python projects
# This file is automatically loaded by direnv when entering the directory

# Use uv environment from pyproject.toml
# This will automatically create/sync environment from pyproject.toml
layout_uv

# Alternative: Use basic Python venv (uncomment if you prefer simplicity)
# layout python3

# Load environment variables from .env file (if it exists)
dotenv

# Add local scripts to path
PATH_add_local

# Project-specific environment variables
export PROJECT_NAME="$(basename $PWD)"
export PYTHONPATH="$PWD:$PYTHONPATH"

# Uncomment for Jupyter projects
# export JUPYTER_CONFIG_DIR="$PWD/.jupyter"

# Uncomment for PyTorch projects
# export PYTORCH_CUDA_ALLOC_CONF="max_split_size_mb:128"

# Uncomment for TensorFlow projects  
# export TF_CPP_MIN_LOG_LEVEL=2

log_status "Python environment loaded for $PROJECT_NAME"

# ============================================================================
# UV QUICK REFERENCE
# ============================================================================
# 
# Initialize new project:     uv init --name $(basename $PWD)
# Add dependencies:           uv add numpy pandas matplotlib
# Add dev dependencies:       uv add --dev pytest black ruff
# Install from requirements:  uv add -r requirements.txt
# Run python:                 uv run python script.py
# Run jupyter:                uv run jupyter lab
# Update environment:         uv sync
# 
# Benefits of uv:
# - 10-100x faster than pip/conda
# - Modern Python standard (pyproject.toml)
# - Better dependency resolution
# - Works with all PyPI packages
# - Single tool for everything
# 
# Files created:
# - pyproject.toml (project definition)
# - uv.lock (exact versions lockfile)
# - .venv/ (local virtual environment)
# ============================================================================
